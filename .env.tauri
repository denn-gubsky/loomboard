# Loaded by `vite --mode tauri` / `vite build --mode tauri` (the Tauri desktop
# build). Unlike the browser/CLI builds there is NO same-origin proxy: the app
# talks to the loomcycle base URL directly over a native-HTTP fetch (routed
# through Rust by @tauri-apps/plugin-http), which bypasses the webview's CORS
# enforcement. Non-secret build flag.
VITE_LOOMBOARD_TAURI=true
