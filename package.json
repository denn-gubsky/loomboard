{
  "name": "loomboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "loomboard — user-facing app for the loomcycle agentic runtime. Rich chat surface first; kanban board later.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@loomcycle/client": "^1.7.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.47",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^7.0.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gemoji": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "http-proxy-middleware": "^3.0.7",
    "typescript": "^5.6.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
